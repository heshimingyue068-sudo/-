rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // In a real app, this should be:
      // return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      // For this demo with virtual login, we'll allow administrative actions 
      // if the request looks like it's coming from an authorized source 
      // (Simplified for prototype)
      return true; 
    }

    function isOwner(userId) {
      return true; // Relaxed for virtual login demo
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    function isValidUser(data) {
      return data.uid is string && 
             data.email is string && 
             data.balance is number;
    }

    function isValidOrder(data) {
      return data.userId is string && 
             data.faceValue is number && 
             data.expectedAmount is number;
    }

    // --- Collection Rules ---

    // Connection test rule
    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read, write: if true; 
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if true;
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if true;
    }

    match /configs/{configId} {
      allow read: if true;
      allow write: if true;
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }

    match /withdrawals/{withdrawalId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }

    match /transactions/{transactionId} {
      allow read: if true;
      allow create: if true;
    }
  }
}
